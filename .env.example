# 环境变量 @see https://www.nextjs.cn/docs/basic-features/environment-variables

# 可在此添加环境变量，去掉最左边的（# ）注释即可
# Notion页面ID,必须
# NOTION_PAGE_ID=097e5f674880459d8e1b4407758dc4fb
# API_BASE_URL=https://www.notion.so/api/v3
# NOTION_API_TOKEN=
# NOTION_API_VERSION=2026-03-11
# NOTION_MEMBERS_DATA_SOURCE_ID=
# NOTION_MEMBERS_PROP_TITLE=title
# NOTION_MEMBERS_PROP_TYPE=type
# NOTION_MEMBERS_PROP_STATUS=status
# NOTION_MEMBERS_PROP_SLUG=slug
# NOTION_MEMBERS_PROP_SUMMARY=summary
# NOTION_MEMBERS_PROP_AVATAR=avatar
# NOTION_MEMBERS_PROP_QUOTE=quote
# NOTION_MEMBERS_PROP_ROLE=role
# NOTION_MEMBERS_PROP_BIO=bio
# NOTION_MEMBERS_PROP_WEBSITE=website
# NOTION_MEMBERS_PROP_SOCIAL_GITHUB=social_github
# NOTION_MEMBERS_PROP_SOCIAL_X=social_x
# NOTION_MEMBERS_PROP_SOCIAL_LINKEDIN=social_linkedin
# NOTION_MEMBERS_PROP_FEATURED=featured
# NOTION_MEMBERS_PROP_VERIFIED=verified
# NOTION_MEMBERS_TYPE_VALUE=Member
# NOTION_MEMBERS_STATUS_DRAFT_VALUE=Invisible
# NOTION_MEMBERS_STATUS_PUBLISHED_VALUE=Published

# 成员头像上传图床，兼容 S3 API / OSS S3 endpoint
# CLOUD_IMAGE_ENDPOINT=
# CLOUD_IMAGE_BUCKET=
# CLOUD_IMAGE_REGION=auto
# CLOUD_IMAGE_ACCESS_KEY_ID=
# CLOUD_IMAGE_SECRET_ACCESS_KEY=
# CLOUD_IMAGE_PUBLIC_BASE_URL=
# CLOUD_IMAGE_PATH_PREFIX=ignai
# CLOUD_IMAGE_URL_STYLE=auto
# 也兼容 R2/OPublish 命名：R2_ACCESS_KEY_ID、R2_SECRET_ACCESS_KEY、
# OPUBLISH_R2_ENDPOINT、OPUBLISH_R2_BUCKET、OPUBLISH_R2_PUBLIC_BASE_URL、OPUBLISH_R2_PREFIX

