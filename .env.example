NEXT_PUBLIC_SITE_URL=https://ignai.community
NEXT_PUBLIC_COMMUNITY_JOIN_URL=/join
NEXT_PUBLIC_CONTACT_EMAIL=hello@ignai.community

# V1 recommended: external application form (Feishu / Wenjuanxing / Notion form)
NEXT_PUBLIC_JOIN_FORM_URL=

# Event registration can be configured per event in Sanity Studio via `registrationUrl`
# Recommended: paste each event's Feishu Bitable / form link directly in the event document

# Sanity Studio + content backend
NEXT_PUBLIC_SANITY_PROJECT_ID=1wxr3e75
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-02-19
SANITY_API_READ_TOKEN=

# V2 optional: Supabase business data backend
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: local inbox path for join submissions when Supabase is not configured
JOIN_LOCAL_STORAGE_PATH=

# Optional social links
NEXT_PUBLIC_WECHAT_URL=
NEXT_PUBLIC_FEISHU_URL=
NEXT_PUBLIC_TELEGRAM_URL=
NEXT_PUBLIC_XIAOHONGSHU_URL=

# Ops protection for the minimal community inbox
OPS_ACCESS_PASSWORD=
